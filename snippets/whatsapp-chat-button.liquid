    <span class="whatsapp-btn-badge" id="whatsappBadge" style="display: none;">✓</span>
  </button>

  <div class="whatsapp-modal" id="whatsappModal">
    <div class="whatsapp-modal-content">
      <div class="whatsapp-modal-header">¿Cómo podemos ayudarte?</div>

      <div class="whatsapp-notification" id="whatsappNotification">
        <span class="whatsapp-notification-icon">✓</span>
        <span>Producto prellenado en el mensaje</span>
      </div>

      <div class="whatsapp-product-selector" id="productSelector" style="display: none;">
        <label for="whatsappProductSelect">Selecciona un producto (opcional)</label>
        <div class="whatsapp-custom-select">
          <select id="whatsappProductSelect">
            <option value="">-- Seleccionar producto --</option>
          </select>
        </div>
      </div>

      <div class="whatsapp-message-preview" id="whatsappPreview"></div>

      <div class="whatsapp-actions">
        <button class="whatsapp-send-btn" id="whatsappSendBtn">Enviar por WhatsApp</button>
        <button class="whatsapp-close-btn" id="whatsappCloseBtn">Cancelar</button>
      </div>
    </div>
  </div>

  <script>
(function() {
  const whatsappPhone = {{ settings.whatsapp_phone | json }};
  const whatsappBtn = document.getElementById('whatsappBtn');
  const whatsappModal = document.getElementById('whatsappModal');
  const whatsappCloseBtn = document.getElementById('whatsappCloseBtn');
  const whatsappSendBtn = document.getElementById('whatsappSendBtn');
  const productSelector = document.getElementById('productSelector');
  const productSelect = document.getElementById('whatsappProductSelect');
  const previewDiv = document.getElementById('whatsappPreview');

  let currentProduct = null;
  let allProducts = [];

  // Construir URL completa del producto
  function buildProductUrl(productUrl) {
    if (!productUrl) return '';
    // Si ya tiene protocolo, devolverlo tal cual
    if (productUrl.startsWith('http')) return productUrl;
    // Si es ruta relativa, agregar el dominio
    const baseUrl = window.location.origin;
    return baseUrl + productUrl;
  }

  // Detectar si estamos en página de producto
  const productData = document.querySelector('[data-product-info]');
  if (productData) {
    const productTitle = productData.getAttribute('data-product-title');
    const productUrl = productData.getAttribute('data-product-url');
    currentProduct = {
      title: productTitle,
      url: buildProductUrl(productUrl)
    };
    // Mostrar badge cuando hay producto prellenado
    document.getElementById('whatsappBadge').style.display = 'flex';
  }

  // Obtener lista de productos si estamos en página genérica
  if (!currentProduct && window.Shopify && window.Shopify.products) {
    allProducts = window.Shopify.products.map(p => ({
      title: p.title,
      url: buildProductUrl(p.url)
    }));
  }

  function updatePreview() {
    let message = 'Hola! Me interesa obtener más información sobre vuestros productos. 😊';
    
    if (currentProduct) {
      message = `Hola! 👋\n\nMe interesa este producto:\n\n${currentProduct.title}\n\n${currentProduct.url}`;
    } else if (productSelect.value) {
      const selected = allProducts.find(p => p.title === productSelect.value);
      if (selected) {
        message = `Hola! 👋\n\nMe interesa este producto:\n\n${selected.title}\n\n${selected.url}`;
      }
    }

    previewDiv.textContent = message;
    return message;
  }

  function openModal() {
    whatsappModal.classList.add('open');
    
    // Mostrar/ocultar notificación de producto prellenado
    const notification = document.getElementById('whatsappNotification');
    if (currentProduct) {
      notification.classList.add('show');
    } else {
      notification.classList.remove('show');
    }
    
    // Solo mostrar selector si no hay producto actual
    if (!currentProduct) {
      productSelector.style.display = 'block';
      
      // Cargar productos en selector
      if (allProducts.length === 0) {
        fetch('/products.json?limit=250')
          .then(r => r.json())
          .then(data => {
            allProducts = data.products.map(p => ({
              title: p.title,
              url: buildProductUrl(p.url)
            }));
            populateProductSelect();
          })
          .catch(() => {
            productSelector.style.display = 'none';
          });
      } else {
        populateProductSelect();
      }
    }

    updatePreview();
  }

  function populateProductSelect() {
    productSelect.innerHTML = '<option value="">-- Seleccionar producto --</option>';
    allProducts.forEach(product => {
      const opt = document.createElement('option');
      opt.value = product.title;
      opt.textContent = product.title;
      productSelect.appendChild(opt);
    });
  }

  function closeModal() {
    whatsappModal.classList.remove('open');
  }

  function sendWhatsApp() {
    const message = updatePreview();
    const encoded = encodeURIComponent(message);
    const waLink = `https://wa.me/${whatsappPhone}?text=${encoded}`;
    window.open(waLink, '_blank');
    closeModal();
  }

  whatsappBtn.addEventListener('click', openModal);
  whatsappCloseBtn.addEventListener('click', closeModal);
  whatsappSendBtn.addEventListener('click', sendWhatsApp);
  productSelect.addEventListener('change', updatePreview);

  // Cerrar modal al hacer click fuera
  whatsappModal.addEventListener('click', (e) => {
    if (e.target === whatsappModal) closeModal();
  });

  // Remover animación después de 6 segundos
  setTimeout(() => {
    whatsappBtn.classList.remove('notify');
  }, 6000);
})();
  </script>
{% endif %}
