<style>
  :root {
    --slide-w: 280px;
    --gap: 20px;
    --speed: 420ms;
    --easing: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --scale: 1.2;
  }

  #cc-{{ section.id }} {
    --cc-bg:                  {{ settings.colors_background_1 }};
    --cc-text:                {{ settings.colors_text }};
    --cc-accent:              {{ settings.colors_accent_2 }};
    --cc-btn-txt:             {{ settings.colors_solid_button_labels }};
    --color-base-background-2: rgb({{ settings.colors_background_2.red }}, {{ settings.colors_background_2.green }}, {{ settings.colors_background_2.blue }});

    background-color: var(--cc-bg);
    padding: 72px 0 96px;
    overflow: hidden;
    position: relative;
  }

  #cc-{{ section.id }} .cc-header {
    text-align: center;
    margin-bottom: 52px;
    padding: 0 24px;
  }

  #cc-{{ section.id }} .cc-title {
    margin: 0;
    line-height: 1;
    color: var(--cc-text);
  }

  #cc-{{ section.id }} .cc-nav {
    position: absolute;
    top: 72px;
    right: 40px;
    display: flex;
    gap: 10px;
  }

  @media (max-width: 768px) {
    #cc-{{ section.id }} .cc-nav { top: 16px; right: 16px; }
  }

  #cc-{{ section.id }} .cc-nav-btn {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--cc-accent) 40%, transparent);
    background: transparent;
    color: var(--cc-text);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  #cc-{{ section.id }} .cc-nav-btn:hover {
    background: var(--cc-accent);
    color: var(--cc-btn-txt);
    border-color: var(--cc-accent);
  }

  #cc-{{ section.id }} .cc-nav-btn svg {
    width: 15px; height: 15px;
    stroke: currentColor; stroke-width: 1.8; fill: none;
    pointer-events: none;
  }

  #cc-{{ section.id }} .cc-viewport {
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    height: 440px;
  }

  #cc-{{ section.id }} .cc-track {
    display: flex;
    will-change: transform;
    transition: transform var(--speed) var(--easing);
    align-items: center;
  }

  #cc-{{ section.id }} .cc-card {
    flex: 0 0 var(--slide-w);
    margin: 0 var(--gap);
    cursor: pointer;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-base-background-2);
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: all 0.3s var(--easing);
  }

  #cc-{{ section.id }} .cc-card.center {
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    position: relative;
    transform: scale(var(--scale));
  }

  #cc-{{ section.id }} .cc-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  #cc-{{ section.id }} .cc-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    user-select: none;
    transition: transform 0.5s var(--easing);
  }

  #cc-{{ section.id }} .cc-card.center .cc-img-wrap img {
    transform: scale(1.04);
  }

  #cc-{{ section.id }} .cc-card-body {
    padding: 16px 18px 18px;
  }

  #cc-{{ section.id }} .cc-name {
    margin: 0 0 4px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--cc-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  #cc-{{ section.id }} .cc-price {
    margin: 0 0 14px;
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--cc-text) 60%, var(--cc-bg));
  }

  #cc-{{ section.id }} .cc-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 36px;
  }

  #cc-{{ section.id }} .cc-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--cc-text) 20%, transparent);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  #cc-{{ section.id }} .cc-dot.active {
    background: var(--cc-accent);
    transform: scale(1.4);
  }
</style>

<section id="cc-{{ section.id }}">
  <div class="cc-header">
    <h2 class="cc-title">{{ section.settings.heading }}</h2>
  </div>

  <div class="cc-nav">
    <button class="cc-nav-btn" id="cc-prev-{{ section.id }}" aria-label="Anterior">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="cc-nav-btn" id="cc-next-{{ section.id }}" aria-label="Siguiente">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
  </div>

  <div class="cc-viewport" id="cc-vp-{{ section.id }}">
    <div class="cc-track" id="cc-track-{{ section.id }}"></div>
  </div>

  <div class="cc-dots" id="cc-dots-{{ section.id }}"></div>
</section>

<script>
(function () {
  {%- assign source_collection = collections[section.settings.collection] -%}
  {%- if source_collection == nil -%}
    {%- assign source_collection = collections.recomendados -%}
  {%- endif -%}

  const rawProducts = [
    {%- assign shown = 0 -%}
    {%- for product in source_collection.products limit: section.settings.products_scan_limit -%}
      {%- if product.featured_image == blank -%}{%- continue -%}{%- endif -%}
      {%- if shown >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
      {
        url:   {{ product.url | json }},
        title: {{ product.title | json }},
        price: {{ product.price | money | json }},
        priceVaries: {{ product.price_varies | json }},
        priceMin: {{ product.price_min | money | json }},
        img:   {{ product.featured_image | image_url: width: 600 | json }},
        alt:   {{ product.featured_image.alt | default: product.title | json }}
      }{% unless forloop.last %},{% endunless %}
      {%- assign shown = shown | plus: 1 -%}
    {%- endfor -%}
  ];

  if (rawProducts.length === 0) return;

  const SLIDE_W       = 280;
  const GAP           = 20;
  const SIZE          = SLIDE_W + GAP * 2;
  const TARGET_SLIDES = 15;
  const AUTOPLAY_ON           = {{ section.settings.autoplay | json }};
  const AUTOPLAY_MS           = {{ section.settings.autoplay_speed }};
  const AUTOPLAY_COOLDOWN_MS  = AUTOPLAY_MS * 5;
  const SECTION_ID            = {{ section.id | json }};

  const track       = document.getElementById('cc-track-' + SECTION_ID);
  const viewport    = document.getElementById('cc-vp-' + SECTION_ID);
  const prevBtn     = document.getElementById('cc-prev-' + SECTION_ID);
  const nextBtn     = document.getElementById('cc-next-' + SECTION_ID);
  const dotsWrap    = document.getElementById('cc-dots-' + SECTION_ID);

  let centerIndex          = 0;
  let isMoving             = false;
  let autoplayEnabled      = false;
  let autoplayId           = null;
  let currentVirtual       = 0;
  let lastManualNavigation = 0;

  const dots = rawProducts.map((_, i) => {
    const btn = document.createElement('button');
    btn.className = 'cc-dot';
    btn.setAttribute('aria-label', 'Ir al producto ' + (i + 1));
    btn.addEventListener('click', () => {
      recordManualNavigation();
      goTo(i);
    });
    dotsWrap.appendChild(btn);
    return btn;
  });

  function updateDots(virtualIdx) {
    const realIdx = ((virtualIdx % rawProducts.length) + rawProducts.length) % rawProducts.length;
    dots.forEach((d, i) => d.classList.toggle('active', i === realIdx));
  }

  function createSlide(virtualIndex) {
    const n   = ((virtualIndex % rawProducts.length) + rawProducts.length) % rawProducts.length;
    const p   = rawProducts[n];
    const div = document.createElement('div');
    div.className     = 'cc-card';
    div.dataset.index = virtualIndex;
    div.dataset.real  = n;

    div.innerHTML = `
      <div class="cc-img-wrap">
        <img src="${p.img}" alt="${p.alt}" loading="lazy" width="600" height="600" draggable="false" ondragstart="return false;">
      </div>
      <div class="cc-card-body">
        <p class="cc-name">${p.title}</p>
        <p class="cc-price">${p.priceVaries ? 'Desde ' + p.priceMin : p.price}</p>
      </div>
    `;

    div.addEventListener('click', () => {
      window.location.href = p.url;
    });

    return div;
  }

  function updateTransform() {
    const vw = viewport.offsetWidth;
    const centerOffset = vw / 2 - SLIDE_W / 2;
    const x = centerOffset - centerIndex * SIZE;
    track.style.transform = `translate3d(${x}px, 0, 0)`;
  }

  function highlightCenter() {
    Array.from(track.children).forEach(s => s.classList.remove('center'));
    const c = track.children[centerIndex];
    if (c) {
      c.classList.add('center');
      currentVirtual = parseInt(c.dataset.index);
      updateDots(currentVirtual);
    }
  }

  function maintainBuffer() {
    const total    = track.children.length;
    if (!total) return;
    const BUFFER_EDGE = Math.floor(TARGET_SLIDES / 3);

    const minIndex = BUFFER_EDGE;
    const maxIndex = total - BUFFER_EDGE - 1;

    if (centerIndex < minIndex) {
      const needed = minIndex - centerIndex;
      for (let i = 0; i < needed; i++) {
        const firstV = parseInt(track.firstElementChild.dataset.index);
        track.prepend(createSlide(firstV - 1));
        centerIndex++;
      }
    }

    if (centerIndex > maxIndex) {
      const needed = centerIndex - maxIndex;
      for (let i = 0; i < needed; i++) {
        const lastV = parseInt(track.lastElementChild.dataset.index);
        track.append(createSlide(lastV + 1));
      }
    }

    while (track.children.length > TARGET_SLIDES) {
      const firstV  = parseInt(track.firstElementChild.dataset.index);
      const lastV   = parseInt(track.lastElementChild.dataset.index);
      const centerV = parseInt(track.children[centerIndex].dataset.index);

      if (centerV - firstV > lastV - centerV) {
        track.removeChild(track.firstElementChild);
        centerIndex--;
      } else {
        track.removeChild(track.lastElementChild);
      }
    }
  }

  function move(dir) {
    if (isMoving) return;
    isMoving = true;

    centerIndex += dir;
    updateTransform();
    highlightCenter();

    const onEnd = () => {
      track.removeEventListener('transitionend', onEnd);
      track.style.transition = 'none';
      maintainBuffer();
      updateTransform();
      highlightCenter();
      void track.offsetHeight;
      track.style.transition = '';
      isMoving = false;
    };

    track.addEventListener('transitionend', onEnd, { once: true });
  }

  function recordManualNavigation() {
    lastManualNavigation = Date.now();
  }

  function goTo(realIndex) {
    if (isMoving) return;
    const currentReal = ((currentVirtual % rawProducts.length) + rawProducts.length) % rawProducts.length;
    let diff = realIndex - currentReal;
    if (diff > rawProducts.length / 2)  diff -= rawProducts.length;
    if (diff < -rawProducts.length / 2) diff += rawProducts.length;
    if (diff === 0) return;
    move(diff);
  }

  function startAutoplay() {
    if (autoplayId) clearInterval(autoplayId);
    autoplayId = setInterval(() => {
      if (Date.now() - lastManualNavigation < AUTOPLAY_COOLDOWN_MS) return;
      if (!isMoving) move(1);
    }, AUTOPLAY_MS);
  }

  function stopAutoplay() {
    if (autoplayId) { clearInterval(autoplayId); autoplayId = null; }
  }

  function init() {
    const half = Math.floor(TARGET_SLIDES / 2);
    for (let i = -half; i <= half; i++) track.appendChild(createSlide(i));
    centerIndex = half;
    updateTransform();
    highlightCenter();

    if (AUTOPLAY_ON) {
      autoplayEnabled = true;
      startAutoplay();
    }
  }

  prevBtn.addEventListener('click', () => {
    recordManualNavigation();
    move(-1);
  });
  nextBtn.addEventListener('click', () => {
    recordManualNavigation();
    move(1);
  });

  viewport.addEventListener('mouseenter', stopAutoplay);
  viewport.addEventListener('mouseleave', () => {
    if (autoplayEnabled) startAutoplay();
  });

  window.addEventListener('resize', () => {
    track.style.transition = 'none';
    updateTransform();
    void track.offsetHeight;
    track.style.transition = '';
  });

  window.addEventListener('beforeunload', stopAutoplay);

  init();
})();
</script>

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Collections"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección",
      "default": "recomendados"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Máximo de productos",
      "default": 20
    },
    {
      "type": "range",
      "id": "products_scan_limit",
      "min": 10,
      "max": 200,
      "step": 1,
      "label": "Máximo de productos a revisar",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "label": "Velocidad autoplay (ms)",
      "default": 4500
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "category": "Productos"
    }
  ]
}
{% endschema %}
