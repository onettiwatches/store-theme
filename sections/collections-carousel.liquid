<style>
  #cc-{{ section.id }} {
    --cc-bg:      {{ settings.colors_background_1 }};
    --cc-bg2:     {{ settings.colors_background_2 }};
    --cc-text:    {{ settings.colors_text }};
    --cc-accent:  {{ settings.colors_accent_2 }};
    --cc-btn-txt: {{ settings.colors_solid_button_labels }};

    background-color: var(--cc-bg);
    padding: 72px 0 96px;
    overflow: hidden;
    position: relative;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  #cc-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 120px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cc-accent), transparent);
  }

  #cc-{{ section.id }} .cc-header {
    text-align: center;
    margin-bottom: 52px;
    padding: 0 24px;
  }

  #cc-{{ section.id }} .cc-eyebrow {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--cc-accent);
    margin-bottom: 12px;
    opacity: 0.85;
  }

  #cc-{{ section.id }} .cc-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cc-text);
    margin: 0;
    line-height: 1;
  }

  #cc-{{ section.id }} .cc-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 16px;
  }

  #cc-{{ section.id }} .cc-ornament-line {
    display: block;
    height: 1px; width: 48px;
    background: linear-gradient(90deg, transparent, var(--cc-accent));
  }

  #cc-{{ section.id }} .cc-ornament-line-r {
    background: linear-gradient(90deg, var(--cc-accent), transparent);
  }

  #cc-{{ section.id }} .cc-ornament svg {
    width: 10px; height: 10px;
    fill: var(--cc-accent);
    opacity: 0.8;
  }

  #cc-{{ section.id }} .cc-nav {
    position: absolute;
    top: 72px; right: 40px;
    display: flex; gap: 10px;
    z-index: 10;
  }

  #cc-{{ section.id }} .cc-nav-btn {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--cc-accent) 35%, transparent);
    background: transparent;
    color: var(--cc-text);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s ease;
    padding: 0;
  }

  #cc-{{ section.id }} .cc-nav-btn:hover {
    background: var(--cc-accent);
    color: var(--cc-btn-txt);
    border-color: var(--cc-accent);
    transform: scale(1.08);
  }

  #cc-{{ section.id }} .cc-nav-btn svg {
    width: 15px; height: 15px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
  }

  #cc-{{ section.id }} .cc-track-wrapper {
    width: 100%;
    overflow: hidden;
  }

  #cc-{{ section.id }} .cc-track {
    display: flex;
    align-items: flex-end;
    padding: 48px 0 64px;
    transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  #cc-{{ section.id }} .cc-card {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    padding: 0 18px;
    transform-origin: bottom center;
    transition: all 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) { opacity: 0.4; transform: scale(0.68) translateY(24px); }
  #cc-{{ section.id }} .cc-card.is-adjacent  { opacity: 0.7; transform: scale(0.82) translateY(12px); }
  #cc-{{ section.id }} .cc-card.is-active    { opacity: 1;   transform: scale(1) translateY(0); z-index: 2; }

  #cc-{{ section.id }} .cc-img-wrap { position: relative; overflow: visible; }

  #cc-{{ section.id }} .cc-img-wrap::before {
    content: '';
    position: absolute;
    bottom: -18px; left: 50%; transform: translateX(-50%);
    width: 65%; height: 36px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.5) 0%, transparent 70%);
    filter: blur(10px);
    transition: all 0.75s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  #cc-{{ section.id }} .cc-card.is-active .cc-img-wrap::before { width: 85%; }

  #cc-{{ section.id }} .cc-card.is-active .cc-img-wrap::after {
    content: '';
    position: absolute;
    inset: -20px; border-radius: 50%;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--cc-accent) 10%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  #cc-{{ section.id }} .cc-card img {
    display: block;
    object-fit: contain;
    transition: all 0.75s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.5));
  }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) img { width: 130px; height: 130px; }
  #cc-{{ section.id }} .cc-card.is-adjacent img                        { width: 195px; height: 195px; }
  #cc-{{ section.id }} .cc-card.is-active    img                       { width: 320px; height: 320px; filter: drop-shadow(0 20px 48px rgba(0,0,0,0.75)); }

  @media (max-width: 768px) {
    #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) img { width: 90px;  height: 90px;  }
    #cc-{{ section.id }} .cc-card.is-adjacent img                        { width: 140px; height: 140px; }
    #cc-{{ section.id }} .cc-card.is-active    img                       { width: 210px; height: 210px; }
    #cc-{{ section.id }} .cc-nav { top: 16px; right: 16px; }
  }

  #cc-{{ section.id }} .cc-name {
    margin-top: 24px;
    font-size: 0.95rem; font-weight: 600; letter-spacing: 0.08em;
    color: var(--cc-text); text-align: center;
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    white-space: nowrap; max-width: 260px;
    overflow: hidden; text-overflow: ellipsis;
  }

  #cc-{{ section.id }} .cc-card.is-active   .cc-name,
  #cc-{{ section.id }} .cc-card.is-adjacent .cc-name { opacity: 1; transform: translateY(0); }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) .cc-name {
    font-size: 0.68rem; opacity: 0.35; transform: translateY(0);
  }

  #cc-{{ section.id }} .cc-price {
    margin-top: 6px;
    font-size: 0.82rem; letter-spacing: 0.1em;
    color: var(--cc-accent);
    opacity: 0; transform: translateY(4px);
    transition: opacity 0.4s ease 0.08s, transform 0.4s ease 0.08s;
  }

  #cc-{{ section.id }} .cc-card.is-active .cc-price { opacity: 1; transform: translateY(0); }

  #cc-{{ section.id }} .cc-cta {
    margin-top: 16px;
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--cc-accent); text-decoration: none;
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.4s ease 0.16s, transform 0.4s ease 0.16s;
    pointer-events: none;
  }

  #cc-{{ section.id }} .cc-cta::after {
    content: '';
    display: block; width: 20px; height: 1px;
    background: var(--cc-accent);
    transition: width 0.3s ease;
  }

  #cc-{{ section.id }} .cc-cta:hover::after { width: 32px; }
  #cc-{{ section.id }} .cc-card.is-active .cc-cta { opacity: 1; transform: translateY(0); pointer-events: auto; }

  #cc-{{ section.id }} .cc-dots {
    display: flex; justify-content: center; align-items: center;
    gap: 8px; margin-top: 44px;
  }

  #cc-{{ section.id }} .cc-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: color-mix(in srgb, var(--cc-accent) 30%, transparent);
    border: none; padding: 0; cursor: pointer;
    transition: all 0.35s ease;
  }

  #cc-{{ section.id }} .cc-dot.is-active { background: var(--cc-accent); transform: scale(1.8); }
</style>

<section id="cc-{{ section.id }}">

  <div class="cc-header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="cc-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2 class="cc-title">{{ section.settings.heading }}</h2>
    <div class="cc-ornament">
      <span class="cc-ornament-line"></span>
      <svg viewBox="0 0 10 10"><polygon points="5,0 6.5,3.5 10,5 6.5,6.5 5,10 3.5,6.5 0,5 3.5,3.5"/></svg>
      <span class="cc-ornament-line cc-ornament-line-r"></span>
    </div>
  </div>

  <div class="cc-nav">
    <button class="cc-nav-btn" id="cc-prev-{{ section.id }}" aria-label="Anterior">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="cc-nav-btn" id="cc-next-{{ section.id }}" aria-label="Siguiente">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
  </div>

  <div class="cc-track-wrapper">
    <div class="cc-track" id="cc-track-{{ section.id }}">

      {%- assign seen_ids = '' -%}
      {%- assign all_products = '' | split: '' -%}
      {%- for col in collections -%}
        {%- for product in col.products limit: 4 -%}
          {%- unless seen_ids contains product.id -%}
            {%- assign seen_ids = seen_ids | append: product.id | append: ',' -%}
            {%- assign all_products = all_products | concat: product -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endfor -%}

      {%- assign card_index = 0 -%}
      {%- for product in all_products limit: section.settings.products_to_show -%}
        <div class="cc-card{% if card_index == 0 %} is-active{% endif %}"
             data-index="{{ card_index }}"
             data-url="{{ product.url }}">
          <div class="cc-img-wrap">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}"
                   alt="{{ product.featured_image.alt | escape | default: product.title }}"
                   loading="lazy" width="500" height="500">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <p class="cc-name">{{ product.title }}</p>
          <p class="cc-price">
            {%- if product.price_varies -%}Desde {{ product.price_min | money }}
            {%- else -%}{{ product.price | money }}{%- endif -%}
          </p>
          <a class="cc-cta" href="{{ product.url }}">{{ section.settings.cta_label }}</a>
        </div>
        {%- assign card_index = card_index | plus: 1 -%}
      {%- endfor -%}

    </div>
  </div>

  <div class="cc-dots" id="cc-dots-{{ section.id }}"></div>

</section>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var track   = document.getElementById('cc-track-' + sid);
  var dots    = document.getElementById('cc-dots-'  + sid);
  var prevBtn = document.getElementById('cc-prev-'  + sid);
  var nextBtn = document.getElementById('cc-next-'  + sid);
  if (!track || !track.querySelector('.cc-card')) return;

  var cards   = Array.from(track.querySelectorAll('.cc-card'));
  var total   = cards.length;
  var current = 0;
  var busy    = false;
  var timer   = null;

  cards.forEach(function (_, i) {
    var d = document.createElement('button');
    d.className = 'cc-dot' + (i === 0 ? ' is-active' : '');
    d.setAttribute('aria-label', 'Ir a ' + (i + 1));
    d.addEventListener('click', function () { go(i); });
    dots.appendChild(d);
  });

  function recenter() {
    requestAnimationFrame(function () {
      var card = cards[current];
      var wrap = track.parentElement.offsetWidth;
      track.style.transform = 'translateX(' + (wrap / 2 - card.offsetLeft - card.offsetWidth / 2) + 'px)';
    });
  }

  function update() {
    cards.forEach(function (c, i) {
      c.classList.remove('is-active', 'is-adjacent');
      var d = Math.min(Math.abs(i - current), total - Math.abs(i - current));
      if      (d === 0) c.classList.add('is-active');
      else if (d === 1) c.classList.add('is-adjacent');
    });
    Array.from(dots.children).forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
    });
    recenter();
  }

  function go(idx) {
    if (busy) return;
    busy = true;
    current = ((idx % total) + total) % total;
    update();
    setTimeout(function () { busy = false; }, 750);
  }

  prevBtn.addEventListener('click', function () { go(current - 1); });
  nextBtn.addEventListener('click', function () { go(current + 1); });

  cards.forEach(function (c, i) {
    c.addEventListener('click', function () {
      if (i !== current) { go(i); return; }
      if (c.dataset.url) location.href = c.dataset.url;
    });
  });

  var sx = 0;
  track.addEventListener('touchstart', function (e) { sx = e.touches[0].clientX; clearInterval(timer); }, { passive: true });
  track.addEventListener('touchend', function (e) {
    if (Math.abs(sx - e.changedTouches[0].clientX) > 40) go(current + (sx > e.changedTouches[0].clientX ? 1 : -1));
    startAuto();
  }, { passive: true });

  function startAuto() {
    clearInterval(timer);
    {% if section.settings.autoplay %}
    timer = setInterval(function () { go(current + 1); }, {{ section.settings.autoplay_speed }});
    {% endif %}
  }

  [prevBtn, nextBtn].forEach(function (b) {
    b.addEventListener('mouseenter', function () { clearInterval(timer); });
    b.addEventListener('mouseleave', startAuto);
  });

  window.addEventListener('resize', recenter);
  update();
  startAuto();
})();
</script>

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto sobre el título",
      "default": "Onetti Watches"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Collections"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Máximo de productos",
      "default": 20
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Ver producto"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "label": "Velocidad autoplay (ms)",
      "default": 4500
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "category": "Productos"
    }
  ]
}
{% endschema %}
