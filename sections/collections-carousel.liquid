<style>
  #cc-{{ section.id }} {
    --cc-bg:      {{ settings.colors_background_1 }};
    --cc-text:    {{ settings.colors_text }};
    --cc-accent:  {{ settings.colors_accent_2 }};
    --cc-btn-txt: {{ settings.colors_solid_button_labels }};

    background-color: var(--cc-bg);
    padding: 72px 0 96px;
    overflow: hidden;
    position: relative;
  }

  #cc-{{ section.id }} .cc-header {
    text-align: center;
    margin-bottom: 52px;
    padding: 0 24px;
  }

  #cc-{{ section.id }} .cc-title {
    margin: 0;
    line-height: 1;
  }

  /* ── NAV ARROWS ── */
  #cc-{{ section.id }} .cc-nav {
    position: absolute;
    top: 72px; right: 40px;
    display: flex; gap: 10px;
    z-index: 10;
  }

  @media (max-width: 768px) {
    #cc-{{ section.id }} .cc-nav { top: 16px; right: 16px; }
  }

  #cc-{{ section.id }} .cc-nav-btn {
    width: 42px; height: 42px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--cc-accent) 40%, transparent);
    background: transparent;
    color: var(--cc-text);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  #cc-{{ section.id }} .cc-nav-btn:hover {
    background: var(--cc-accent);
    color: var(--cc-btn-txt);
    border-color: var(--cc-accent);
    transform: scale(1.08);
  }

  #cc-{{ section.id }} .cc-nav-btn svg {
    width: 15px; height: 15px;
    stroke: currentColor; stroke-width: 1.8; fill: none;
  }

  /* ── TRACK WRAPPER — FIXED HEIGHT so layout never jumps ── */
  #cc-{{ section.id }} .cc-track-wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
    height: 520px;   /* desktop: tallest card (340px img) + labels + shadow room */
  }

  @media (max-width: 768px) {
    #cc-{{ section.id }} .cc-track-wrapper { height: 340px; }
  }

  /* ── TRACK — anchored to the bottom of the wrapper ── */
  #cc-{{ section.id }} .cc-track {
    display: flex;
    align-items: flex-end;   /* cards grow upward from shared baseline */
    position: absolute;
    bottom: 0; left: 0;
    height: 100%;
    /* transition toggled by JS (disabled for instant teleport) */
    will-change: transform;
  }

  /* ── CARDS ── */
  #cc-{{ section.id }} .cc-card {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    padding: 0 28px;
    transform-origin: bottom center;
    transition:
      opacity   0.75s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) {
    opacity: 0.3;
    transform: scale(0.62) translateY(32px);
  }

  #cc-{{ section.id }} .cc-card.is-adjacent {
    opacity: 0.7;
    transform: scale(0.78) translateY(16px);
  }

  #cc-{{ section.id }} .cc-card.is-active {
    opacity: 1;
    transform: scale(1) translateY(0);
    z-index: 2;
  }

  /* ── IMAGE WRAP ── */
  #cc-{{ section.id }} .cc-img-wrap {
    position: relative;
    overflow: visible;
    background: transparent;
  }

  #cc-{{ section.id }} .cc-img-wrap::before {
    content: '';
    position: absolute;
    bottom: -18px; left: 50%;
    transform: translateX(-50%);
    width: 55%; height: 28px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.45) 0%, transparent 72%);
    filter: blur(10px);
    transition: width 0.75s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.75s ease;
    pointer-events: none;
    opacity: 0.6;
  }

  #cc-{{ section.id }} .cc-card.is-active .cc-img-wrap::before {
    width: 88%;
    opacity: 0.85;
  }

  #cc-{{ section.id }} .cc-card.is-active .cc-img-wrap::after {
    content: '';
    position: absolute;
    inset: -28px;
    border-radius: 50%;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--cc-accent) 10%, transparent) 0%, transparent 68%);
    pointer-events: none;
    animation: cc-halo-in 0.55s ease both;
  }

  @keyframes cc-halo-in {
    from { opacity: 0; transform: scale(0.75); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── PRODUCT IMAGE ── */
  #cc-{{ section.id }} .cc-card img {
    display: block;
    object-fit: contain;
    background: transparent;
    border-radius: 0;
    transition:
      width   0.75s cubic-bezier(0.22, 1, 0.36, 1),
      height  0.75s cubic-bezier(0.22, 1, 0.36, 1),
      filter  0.75s ease;
  }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) img {
    width: 110px; height: 110px;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.35)) brightness(0.78);
  }
  #cc-{{ section.id }} .cc-card.is-adjacent img {
    width: 190px; height: 190px;
    filter: drop-shadow(0 8px 22px rgba(0,0,0,0.45)) brightness(0.92);
  }
  #cc-{{ section.id }} .cc-card.is-active img {
    width: 340px; height: 340px;
    filter: drop-shadow(0 22px 52px rgba(0,0,0,0.65)) brightness(1);
  }

  @media (max-width: 768px) {
    #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) img { width: 72px;  height: 72px;  }
    #cc-{{ section.id }} .cc-card.is-adjacent img                        { width: 130px; height: 130px; }
    #cc-{{ section.id }} .cc-card.is-active    img                       { width: 210px; height: 210px; }
  }

  /* ── LABELS ── */
  #cc-{{ section.id }} .cc-name {
    margin-top: 22px;
    font-size: 0.9rem; font-weight: 600; letter-spacing: 0.09em;
    color: var(--cc-text); text-align: center;
    white-space: nowrap; max-width: 280px;
    overflow: hidden; text-overflow: ellipsis;
    transition: opacity 0.5s ease 0.08s, font-size 0.5s ease 0.08s, transform 0.5s ease 0.08s;
  }

  #cc-{{ section.id }} .cc-card:not(.is-active):not(.is-adjacent) .cc-name {
    font-size: 0.6rem; opacity: 0.25; transform: translateY(3px);
  }
  #cc-{{ section.id }} .cc-card.is-adjacent .cc-name {
    font-size: 0.75rem; opacity: 0.65; transform: translateY(0);
  }
  #cc-{{ section.id }} .cc-card.is-active .cc-name {
    font-size: 0.9rem; opacity: 1; transform: translateY(0);
  }

  #cc-{{ section.id }} .cc-price {
    margin-top: 6px;
    font-size: 0.8rem; letter-spacing: 0.12em;
    color: var(--cc-accent);
    transition: opacity 0.45s ease 0.16s, transform 0.45s ease 0.16s;
  }

  #cc-{{ section.id }} .cc-card:not(.is-active) .cc-price { opacity: 0; transform: translateY(5px); }
  #cc-{{ section.id }} .cc-card.is-active        .cc-price { opacity: 1; transform: translateY(0); }

  #cc-{{ section.id }} .cc-cta {
    margin-top: 14px;
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--cc-accent); text-decoration: none;
    pointer-events: none;
    transition: opacity 0.45s ease 0.24s, transform 0.45s ease 0.24s;
  }

  #cc-{{ section.id }} .cc-cta::after {
    content: '';
    display: block; width: 20px; height: 1px;
    background: var(--cc-accent);
    transition: width 0.3s ease;
  }

  #cc-{{ section.id }} .cc-cta:hover::after { width: 32px; }

  #cc-{{ section.id }} .cc-card:not(.is-active) .cc-cta { opacity: 0; transform: translateY(7px); }
  #cc-{{ section.id }} .cc-card.is-active        .cc-cta { opacity: 1; transform: translateY(0); pointer-events: auto; }

  /* ── DOTS ── */
  #cc-{{ section.id }} .cc-dots {
    display: flex; justify-content: center; align-items: center;
    gap: 8px; margin-top: 32px;
  }

  #cc-{{ section.id }} .cc-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: color-mix(in srgb, var(--cc-accent) 28%, transparent);
    border: none; padding: 0; cursor: pointer;
    transition: background 0.35s ease, transform 0.35s ease;
  }

  #cc-{{ section.id }} .cc-dot.is-active {
    background: var(--cc-accent);
    transform: scale(1.9);
  }
</style>

<section id="cc-{{ section.id }}">
  <div class="cc-header">
    <h2 class="cc-title">{{ section.settings.heading }}</h2>
  </div>

  <div class="cc-nav">
    <button class="cc-nav-btn" id="cc-prev-{{ section.id }}" aria-label="Anterior">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="cc-nav-btn" id="cc-next-{{ section.id }}" aria-label="Siguiente">
      <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
    </button>
  </div>

  <div class="cc-track-wrapper">
    <div class="cc-track" id="cc-track-{{ section.id }}">

      {%- assign card_index = 0 -%}
      {%- for product in collections.all.products limit: 50 -%}
        {%- if product.featured_image == blank -%}{%- continue -%}{%- endif -%}
        {%- if card_index >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
        <div class="cc-card"
             data-index="{{ card_index }}"
             data-url="{{ product.url }}">
          <div class="cc-img-wrap">
            {{-
              product.featured_image
              | image_url: width: 600
              | image_tag:
                  loading: 'lazy',
                  alt: product.featured_image.alt | default: product.title,
                  width: 600,
                  height: 600
            -}}
          </div>
          <p class="cc-name">{{ product.title }}</p>
          <p class="cc-price">
            {%- if product.price_varies -%}Desde {{ product.price_min | money }}
            {%- else -%}{{ product.price | money }}{%- endif -%}
          </p>
          <a class="cc-cta" href="{{ product.url }}">{{ section.settings.cta_label }}</a>
        </div>
        {%- assign card_index = card_index | plus: 1 -%}
      {%- endfor -%}

    </div>
  </div>

  <div class="cc-dots" id="cc-dots-{{ section.id }}"></div>
</section>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var track   = document.getElementById('cc-track-' + sid);
  var dotsEl  = document.getElementById('cc-dots-'  + sid);
  var prevBtn = document.getElementById('cc-prev-'  + sid);
  var nextBtn = document.getElementById('cc-next-'  + sid);
  if (!track || !track.querySelector('.cc-card')) return;

  /* ─────────────────────────────────────────────────────────────
     TRUE INFINITE LOOP — clone-teleport technique
     ─────────────────────────────────────────────────────────────
     Layout in the DOM:
       [before-clones: N cards] [originals: N cards] [after-clones: N cards]

     We always navigate inside the middle (original) zone.
     When we cross into a clone zone, after the CSS animation
     finishes we instantly teleport (transition:none) to the
     matching card in the original zone. The clones are pixel-
     identical so the jump is invisible.
  ─────────────────────────────────────────────────────────────── */

  var originals = Array.from(track.querySelectorAll('.cc-card'));
  var N         = originals.length;
  var timer     = null;
  var busy      = false;

  /* Dots for original N items */
  originals.forEach(function (_, i) {
    var d = document.createElement('button');
    d.className = 'cc-dot';
    d.setAttribute('aria-label', 'Ir a ' + (i + 1));
    d.addEventListener('click', function () { goToOrig(i); });
    dotsEl.appendChild(d);
  });
  var dotBtns = Array.from(dotsEl.children);

  /* Clone sets */
  function cloneSet() {
    return originals.map(function (c) {
      var cl = c.cloneNode(true);
      cl.setAttribute('aria-hidden', 'true');
      cl.classList.add('cc-clone');
      return cl;
    });
  }

  var beforeClones = cloneSet();
  var afterClones  = cloneSet();

  /* Prepend before-clones (keep original order) */
  beforeClones.slice().reverse().forEach(function (cl) {
    track.insertBefore(cl, track.firstChild);
  });
  /* Append after-clones */
  afterClones.forEach(function (cl) { track.appendChild(cl); });

  /* Full flat list: [before N] [orig N] [after N] */
  var allCards = Array.from(track.querySelectorAll('.cc-card'));
  /* pos = absolute index in allCards; start at first original */
  var pos = N;

  /* ── helpers ── */
  function origIdx(absIdx) {
    /* wrap any absolute index to 0…N-1 */
    return ((absIdx % N) + N) % N;
  }

  function setAnim(on) {
    track.style.transition = on
      ? 'transform 0.75s cubic-bezier(0.22, 1, 0.36, 1)'
      : 'none';
  }

  function applyTranslate() {
    var wrap   = track.parentElement.offsetWidth;
    var card   = allCards[pos];
    var offset = wrap / 2 - card.offsetLeft - card.offsetWidth / 2;
    track.style.transform = 'translateX(' + offset + 'px)';
  }

  function updateClasses() {
    var ri = origIdx(pos);
    allCards.forEach(function (c, i) {
      c.classList.remove('is-active', 'is-adjacent');
      var d = Math.min(Math.abs(origIdx(i) - ri), N - Math.abs(origIdx(i) - ri));
      if      (d === 0) c.classList.add('is-active');
      else if (d === 1) c.classList.add('is-adjacent');
    });
    dotBtns.forEach(function (d, i) {
      d.classList.toggle('is-active', i === ri);
    });
  }

  function render(animated) {
    setAnim(animated);
    updateClasses();
    applyTranslate();
  }

  /* After animated move: teleport if we drifted into a clone zone */
  function onTransitionEnd() {
    var jumped = false;
    if (pos < N)       { pos += N; jumped = true; }
    if (pos >= 2 * N)  { pos -= N; jumped = true; }
    if (jumped) render(false);  /* instant, invisible */
    busy = false;
  }

  track.addEventListener('transitionend', function (e) {
    if (e.propertyName === 'transform') onTransitionEnd();
  });

  /* ── step by delta ── */
  function step(delta) {
    if (busy) return;
    busy = true;
    pos += delta;
    render(true);
    /* safety fallback */
    setTimeout(function () { if (busy) onTransitionEnd(); }, 950);
  }

  /* ── jump to a specific original index (dot click) ── */
  function goToOrig(ri) {
    if (busy) return;
    var cur = origIdx(pos);
    var delta = ri - cur;
    /* pick shortest arc */
    if (delta >  N / 2) delta -= N;
    if (delta < -N / 2) delta += N;
    if (delta === 0) return;
    step(delta);
  }

  /* ── click on a card ── */
  allCards.forEach(function (c, i) {
    c.addEventListener('click', function () {
      var ci  = origIdx(i);
      var cur = origIdx(pos);
      if (ci !== cur) { goToOrig(ci); return; }
      /* clicked the active card — navigate to product */
      var orig = originals[cur];
      if (orig && orig.dataset.url) location.href = orig.dataset.url;
    });
  });

  /* ── controls ── */
  prevBtn.addEventListener('click', function () { step(-1); });
  nextBtn.addEventListener('click', function () { step(1);  });

  /* ── swipe ── */
  var sx = 0;
  track.addEventListener('touchstart', function (e) {
    sx = e.touches[0].clientX;
    clearInterval(timer);
  }, { passive: true });

  track.addEventListener('touchend', function (e) {
    if (Math.abs(sx - e.changedTouches[0].clientX) > 40)
      step(sx > e.changedTouches[0].clientX ? 1 : -1);
    startAuto();
  }, { passive: true });

  /* ── autoplay ── */
  function startAuto() {
    clearInterval(timer);
    {% if section.settings.autoplay %}
    timer = setInterval(function () { step(1); }, {{ section.settings.autoplay_speed }});
    {% endif %}
  }

  [prevBtn, nextBtn].forEach(function (b) {
    b.addEventListener('mouseenter', function () { clearInterval(timer); });
    b.addEventListener('mouseleave', startAuto);
  });

  window.addEventListener('resize', function () { render(false); });

  /* ── init ── */
  render(false);
  startAuto();
})();
</script>

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Collections"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 30,
      "step": 1,
      "label": "Máximo de productos",
      "default": 20
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Ver producto"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "label": "Velocidad autoplay (ms)",
      "default": 4500
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "category": "Productos"
    }
  ]
}
{% endschema %}
